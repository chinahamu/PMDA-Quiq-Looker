{
  "name": "pmda-quick-looker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Chrome extension for quick PMDA package insert lookup.",
  "packageManager": "npm@10.9.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "serve:e2e": "npx -y sirv-cli dist --port 5173 --host 127.0.0.1 --strict",
    "test:ci": "npm run lint && npm run build && npm run test:unit && npm run test:e2e",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "idb": "^8.0.0",
    "vite": "^6.3.5",
    "typescript": "^5.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.53.1",
    "@types/chrome": "^0.0.318",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fake-indexeddb": "^6.0.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "msw": "^2.10.2",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.3"
  }
}
