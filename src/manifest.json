{
  "manifest_version": 3,
  "name": "PMDA Quick Looker",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "description": "WEBブラウザ上で選択した薬品名からPMDA添付文書を素早く参照するChrome拡張です。",
  "permissions": [
    "contextMenus",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://drugwiki.meta-alchemist.co.jp/*",
    "https://www.pmda.go.jp/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://drugwiki.meta-alchemist.co.jp https://www.pmda.go.jp; img-src 'self' https://www.pmda.go.jp data:; frame-src https://www.pmda.go.jp;"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "PMDA Quick Looker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  }
}